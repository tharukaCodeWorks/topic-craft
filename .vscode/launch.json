{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "TopicCraft: Main",
      "type": "node",
      "request": "launch",
      "protocol": "inspector",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "start"
      ],
      "env": {
        "MAIN_ARGS": "--inspect=5858 --remote-debugging-port=9223"
      }
    },
    {
      "name": "TopicCraft: Renderer",
      "type": "chrome",
      "request": "attach",
      "port": 9223,
      "webRoot": "${workspaceFolder}",
      "timeout": 15000
    }
  ],
  "compounds": [
    {
      "name": "TopicCraft: All",
      "configurations": [
        "TopicCraft: Main",
        "TopicCraft: Renderer"
      ]
    }
  ]
}